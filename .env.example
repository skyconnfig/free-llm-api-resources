# ============================================
# 免费 LLM API 资源 - 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入你的 API 密钥
# 注意：不要将 .env 文件提交到版本控制系统

# --------------------------------------------
# Groq - 高速 AI 推理平台
# 注册地址: https://console.groq.com
# --------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# --------------------------------------------
# Hyperbolic - 去中心化 AI 计算网络
# 注册地址: https://app.hyperbolic.ai
# --------------------------------------------
HYPERBOLIC_API_KEY=your_hyperbolic_api_key_here

# --------------------------------------------
# Cloudflare Workers AI - 边缘 AI 推理
# 注册地址: https://dash.cloudflare.com
# --------------------------------------------
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_KEY=your_cloudflare_api_key

# --------------------------------------------
# Lambda Labs - GPU 云平台
# 注册地址: https://cloud.lambdalabs.com
# --------------------------------------------
LAMBDA_API_KEY=your_lambda_api_key_here

# --------------------------------------------
# Scaleway - 欧洲云服务商
# 注册地址: https://console.scaleway.com
# --------------------------------------------
SCALEWAY_API_KEY=your_scaleway_api_key_here

# --------------------------------------------
# Cohere - 企业级语言模型平台
# 注册地址: https://dashboard.cohere.com
# --------------------------------------------
COHERE_API_KEY=your_cohere_api_key_here

# --------------------------------------------
# Google Cloud Platform - Gemini 配额查询
# 需要设置 Google Cloud 认证凭证
# 文档: https://cloud.google.com/docs/authentication
# --------------------------------------------
GCP_PROJECT_ID=your_gcp_project_id

# --------------------------------------------
# 其他配置
# --------------------------------------------

# 是否并发获取数据（true/false）
# 默认为 false，设置为 true 可以加快速度但可能触发限流
FETCH_CONCURRENTLY=false
